v="abciiidef"
k=3
vowels = "aeiou"
max_vowels = 0
for i in range(k,len(v)):
    if v[i] in vowels :
        max_vowels=max_vowels+1
maxs=max_vowels
for i in range (k,len(v)):
    if v[i-k] in vowels:
        max_vowels=max_vowels-1
    if v[i] in vowels:  
        maxs=max(maxs,max_vowels)
print(maxs)
